# Copy to .env and fill in real values before deploying. NEVER commit the real .env.
DATABASE_URL=jdbc:postgresql://localhost:5432/sandeshx
DATABASE_USER=sandeshx
DATABASE_PASSWORD=change-me

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
# REQUIRED for uploads to work from a real phone: the address the backend uses above
# (MINIO_ENDPOINT) only needs to be reachable *from the backend server itself* — it's
# often "localhost" or an internal Docker hostname, neither of which a phone can reach.
# Set this to the public URL of your MinIO/S3-compatible storage (e.g.
# https://media.yourdomain.com) and presigned upload/download links will use it instead.
# If unset, it falls back to MINIO_ENDPOINT above — which is why photo/DP uploads fail
# by default on a fresh deploy.
MINIO_PUBLIC_ENDPOINT=

# Generate with: openssl rand -hex 32 — must be long/random, never a default in prod
JWT_SECRET=

# Comma-free single origin your Android/web app is served from, e.g. https://sandeshx.app
ALLOWED_ORIGIN=

# Plug in Twilio/MSG91 credentials here once you replace LogSmsSender with a real provider
SMS_PROVIDER_API_KEY=

# MYRA AI assistant — get a free key at https://aistudio.google.com/apikey
# Without this, MYRA replies with a message saying she isn't configured yet.
GEMINI_API_KEY=

# Optional — needed only if you want the "use my own API key" Settings option
# to work. Any random long string is fine; generate one with: openssl rand -hex 32
# Without this set, users can still use MYRA via your shared GEMINI_API_KEY above,
# they just won't be able to add their own personal key.
FIELD_ENCRYPTION_SECRET=
# Optional — defaults to gemini-2.5-flash if unset
GEMINI_MODEL=

# Twilio — sends real OTP SMS. If any of these three are missing, the server falls
# back to logging the OTP instead of sending it (fine for local dev, not for prod).
ACCOUNT_SID=
AUTH_TOKEN=
# The Twilio phone number to send FROM, in E.164 format (Twilio Console → Phone Numbers).
TWILIO_FROM_NUMBER=
